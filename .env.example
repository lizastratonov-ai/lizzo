DISCORD_TOKEN=your-discord-bot-token
CLIENT_ID=your-discord-application-client-id
GUILD_ID=your-private-server-id

# Optional: improves Spotify track-link support if auto-detection fails.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_TOP_TRACKS_COUNTRY=US

# Optional: only needed if you want to use your own SoundCloud credentials.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_OAUTH_TOKEN=

# Optional: path to a Netscape-format YouTube cookies file for yt-dlp.
# Production deploys default to /opt/lizzo/youtube-cookies.txt.
YTDLP_COOKIES_PATH=
